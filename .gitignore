# ============================================
# 通用忽略规则
# ============================================

# OS 文件
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量
.env
.env.local
.env.*.local

# 备份文件
*.backup.*
*.bak
*.zip

# ============================================
# 后端 (server/) 忽略规则
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# 虚拟环境
server/venv/
server/ENV/
server/env/
server/.venv

# 数据库
server/instance/
server/*.db
server/*.sqlite
server/*.sqlite3

# ============================================
# 前端 (web/) 忽略规则
# ============================================

# 依赖目录
web/node_modules/
web/.pnp
web/.pnp.js

# 构建输出
web/build/
web/dist/

# 测试覆盖率
web/coverage/

# 本地环境
web/.env.local
web/.env.development.local
web/.env.test.local
web/.env.production.local
